rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read and write only their own reviews
    match /reviews/{reviewId} {
      allow read, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // Users can read and write only their own preferences
    match /users/{uid}/settings/{document} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // rateLimits is only accessed via Admin SDK — deny all client access
    match /rateLimits/{docId} {
      allow read, write: if false;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
