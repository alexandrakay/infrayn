rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read and write only their own reviews; anyone can read by ID (shareable links)
    match /reviews/{reviewId} {
      allow get: if true;
      allow list: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['resolvedFindings']);
    }

    // Users can read and write only their own preferences
    match /users/{uid}/settings/{document} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Users can read and write only their own custom templates
    match /users/{uid}/templates/{document} {
      allow read, write, delete: if request.auth != null && request.auth.uid == uid;
    }

    // rateLimits is only accessed via Admin SDK — deny all client access
    match /rateLimits/{docId} {
      allow read, write: if false;
    }

    // Analytics events — append-only, no auth required
    match /events/{eventId} {
      allow create: if request.resource.data.keys().hasAll(['event', 'sessionId', 'timestamp']);
      allow read, update, delete: if false;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
